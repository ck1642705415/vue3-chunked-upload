{
  "name": "vue3-chunked-upload",
  "version": "1.0.3",
  "type": "module",
  "description": "基于 Vue 3 的分片上传组件，支持断点续传、并发上传、失败重试等功能",
  "author": "chenkai1993",
  "license": "MIT",
  "keywords": [
    "vue",
    "vue3",
    "upload",
    "chunked-upload",
    "resumable",
    "typescript"
  ],
  "main": "./dist/index.umd.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "vue": "^3.2.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "autoprefixer": "^10.5.3",
    "postcss": "^8.5.19",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vite-plugin-dts": "^3.0.0",
    "vue": "^3.4.0"
  },
  "repository": {
    "type": "git",
    "url": ""
  }
}
